@page
@model CMS.Web.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="page-container">

    <h1>Access denied</h1>

    <!--
        role="alert" announces the error state to screen readers immediately (WCAG 4.1.3 AA).
        role="status" is used for informational banners; role="alert" for errors/access issues.
    -->
    <div role="alert" class="validation-summary">
        <p>
            <strong>You do not have permission to view this page.</strong>
        </p>
        <p>
            This page requires a specific role that your account does not have.
            Please sign in with an account that has the correct permissions,
            or contact your administrator.
        </p>
    </div>

    <div class="form-actions">
        <a href="/" class="btn btn-primary">Return to home</a>
    </div>

</div>
