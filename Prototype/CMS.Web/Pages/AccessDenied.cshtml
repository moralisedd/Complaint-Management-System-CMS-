@page "/access-denied"
@model CMS.Web.Pages.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="page-container">
    <h1>Access Denied</h1>

    @*
        role="alert" announces the message to screen readers immediately on page load (WCAG 4.1.3).
        role="status" is for informational banners; role="alert" is correct for access denied errors.
    *@
    <div role="alert" class="validation-summary">
        <p><strong>You don't have permission to view this page.</strong></p>
        <p>
            This page requires a role your account doesn't have.
            Sign in with an account that has the correct permissions,
            or contact your administrator if you think this is a mistake.
        </p>
    </div>

    <div class="form-actions">
        <a href="/" class="btn btn-primary">Return to home</a>
    </div>
</div>
